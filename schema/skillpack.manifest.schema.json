{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/skillpack.manifest.schema.json",
  "title": "Skill Pack Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "version", "purpose", "summary", "dependsOn", "helpers", "jscpid"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable pack name used for selection and dependency resolution."
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "description": "Pack version."
    },
    "purpose": {
      "type": "string",
      "minLength": 1,
      "description": "What this pack exists to optimize or stabilize."
    },
    "summary": {
      "type": "string",
      "description": "Short pack summary."
    },
    "dependsOn": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "description": "Names of packs that must load before this one."
    },
    "helpers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/helper"
      },
      "description": "Helper definitions contained in this pack."
    },
    "jscpid": {
      "type": "string",
      "pattern": "^jscpid_[0-9a-f]{16}$",
      "description": "Deterministic semantic identifier for the pack."
    }
  },
  "$defs": {
    "helper": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "purpose", "tags", "content", "references", "jscpid"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Stable helper identifier inside the pack."
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "description": "Display title for the helper."
        },
        "purpose": {
          "type": "string",
          "minLength": 1,
          "description": "Why the helper exists and when it should be used."
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "description": "Normalized tags used to group helpers."
        },
        "content": {
          "type": "string",
          "minLength": 1,
          "description": "Normalized helper body or snippet."
        },
        "references": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "description": "Paths or links that support the helper."
        },
        "jscpid": {
          "type": "string",
          "pattern": "^jscpid_[0-9a-f]{16}$",
          "description": "Deterministic semantic identifier for the helper."
        }
      }
    }
  }
}
