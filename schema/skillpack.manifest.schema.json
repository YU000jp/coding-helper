{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/skillpack.manifest.schema.json",
  "title": "Skill Pack Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "version", "purpose", "summary", "dependsOn", "skills", "jscpid"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable pack name used for selection and dependency resolution."
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "description": "Pack version."
    },
    "purpose": {
      "type": "string",
      "description": "What this pack exists to optimize or stabilize."
    },
    "summary": {
      "type": "string",
      "description": "Short pack summary."
    },
    "dependsOn": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "description": "Names of packs that must load before this one."
    },
    "skills": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/skill"
      },
      "description": "Skill definitions contained in this pack."
    },
    "jscpid": {
      "type": "string",
      "pattern": "^jscpid_[0-9a-f]{16}$",
      "description": "Deterministic semantic identifier for the pack."
    }
  },
  "$defs": {
    "skill": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "summary", "purpose", "contracts", "guarantees", "usagePatterns", "implementations", "jscpid"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Stable skill identifier inside the pack."
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "description": "Display title for the skill."
        },
        "summary": {
          "type": "string",
          "description": "One-line summary of the skill."
        },
        "purpose": {
          "type": "string",
          "description": "Why the skill exists and when it should be used."
        },
        "contracts": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "description": "Behavioral constraints the skill promises to respect."
        },
        "guarantees": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "description": "Outcomes the skill aims to preserve."
        },
        "usagePatterns": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "description": "Recommended usage patterns for the AI runtime."
        },
        "dependsOn": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "description": "Skill-local dependencies."
        },
        "implementations": {
          "type": "object",
          "additionalProperties": false,
          "required": ["ts", "rust"],
          "properties": {
            "ts": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "default": [],
              "description": "Links or paths to TypeScript implementations."
            },
            "rust": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "default": [],
              "description": "Links or paths to Rust implementations."
            }
          }
        },
        "jscpid": {
          "type": "string",
          "pattern": "^jscpid_[0-9a-f]{16}$",
          "description": "Deterministic semantic identifier for the skill."
        }
      }
    }
  }
}
