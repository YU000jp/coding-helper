{
  "name": "@yu000jp/skillpack-helper",
  "version": "0.1.0",
  "description": "Support library for packaging AI coding knowledge into reusable skill packs.",
  "homepage": "https://github.com/YU000jp/skillpack-helper#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YU000jp/skillpack-helper.git"
  },
  "bugs": {
    "url": "https://github.com/YU000jp/skillpack-helper/issues"
  },
  "keywords": [
    "ai",
    "coding",
    "helper",
    "skills",
    "workspace",
    "prompting"
  ],
  "author": "YU000jp",
  "type": "commonjs",
  "main": "src/index.js",
  "exports": {
    ".": {
      "require": "./src/index.js",
      "import": "./src/index.js",
      "default": "./src/index.js"
    },
    "./package.json": "./package.json",
    "./schema/skillpack.manifest.schema.json": "./schema/skillpack.manifest.schema.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "schema",
    "README.md",
    "package.json"
  ],
  "bin": {
    "skillpack-helper": "src/cli.js"
  },
  "scripts": {
    "test": "node --test",
    "start": "node src/cli.js"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
