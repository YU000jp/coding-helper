{
  "name": "coding-helper",
  "version": "0.1.0",
  "description": "Helper pack npm module for stable AI coding workflows.",
  "keywords": [
    "ai",
    "coding",
    "helper",
    "skills",
    "workspace",
    "prompting"
  ],
  "author": "OpenAI",
  "type": "commonjs",
  "main": "src/index.js",
  "exports": {
    ".": {
      "require": "./src/index.js",
      "import": "./src/index.js",
      "default": "./src/index.js"
    },
    "./package.json": "./package.json",
    "./schema/skillpack.manifest.schema.json": "./schema/skillpack.manifest.schema.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "schema",
    "README.md",
    "package.json"
  ],
  "bin": {
    "coding-helper": "src/cli.js"
  },
  "scripts": {
    "test": "node --test",
    "start": "node src/cli.js"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
